# 完成时间：2026-03-19 01:00 UTC
# 大学录取信息整理系统 - 环境变量示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 应用配置 ====================
# 运行环境：development, production
ENVIRONMENT=development

# 应用端口
PORT=8000

# 时区
TZ=Asia/Shanghai

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
# SQLite（开发环境）
DATABASE_URL=sqlite:///./data/admission_system.db

# MySQL（生产环境，可选）
# DATABASE_URL=mysql://user:password@localhost:3306/admission_system

# ==================== Redis 配置 ====================
# Redis 连接 URL
REDIS_URL=redis://localhost:6379/0

# ==================== OpenClaw 集成（可选） ====================
# OpenClaw API 地址
# OPENCLAW_API_URL=http://localhost:8080

# OpenClaw API 密钥
# OPENCLAW_API_KEY=your_api_key_here

# ==================== 文件存储 ====================
# 上传文件存储路径
UPLOAD_DIR=./data/uploads

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE=10

# ==================== 安全配置 ====================
# JWT 密钥（生产环境请修改）
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=24

# CORS 允许的来源（生产环境请修改）
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==================== 任务队列 ====================
# 任务队列后端：redis, database
TASK_QUEUE_BACKEND=redis

# 任务并发数
TASK_WORKERS=4

# ==================== 邮件通知（可选） ====================
# SMTP 服务器
# SMTP_HOST=smtp.example.com

# SMTP 端口
# SMTP_PORT=587

# SMTP 用户名
# SMTP_USER=your_email@example.com

# SMTP 密码
# SMTP_PASSWORD=your_password

# 发件人邮箱
# SMTP_FROM=noreply@example.com
