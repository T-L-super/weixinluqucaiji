@app.get("/api/records")
async def get_records(page: int = 1, page_size: int = 50):
    """简化版 API - 直接查询所有记录"""
    import sqlite3
    conn = sqlite3.connect('/root/.openclaw/workspace/大学录取信息整理系统/data/admission_system.db')
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()
    
    cursor.execute("SELECT * FROM admission_records ORDER BY created_at DESC LIMIT ? OFFSET ?", [page_size, (page - 1) * page_size])
    rows = cursor.fetchall()
    
    cursor.execute("SELECT COUNT(*) FROM admission_records")
    total = cursor.fetchone()[0]
    conn.close()
    
    records = [dict(row) for row in rows]
    return {"records": records, "total": total, "page": page, "page_size": page_size, "total_pages": (total + page_size - 1) // page_size}

