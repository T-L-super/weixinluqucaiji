        "permissions": current_user["permissions"]
    }


@app.post("/api/auth/register")
async def register(request: UserCreateRequest, current_user: dict = Depends(get_current_user)):
    """注册用户（需要管理员权限）"""
    if not has_permission(current_user, "manage_users"):
        raise HTTPException(status_code=403, detail="权限不足，无法注册用户")
    
    new_user = create_user(
        username=request.username,
        password=request.password,
        email=request.email,
        full_name=request.full_name,
        role_id=request.role_id
    )
    
    return {"message": "用户创建成功", "user": new_user}


