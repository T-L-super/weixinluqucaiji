@app.put("/api/users/{user_id}")
async def update_user(user_id: int, request: UserUpdateRequest, current_user: dict = Depends(get_current_user)):
    """更新用户信息（需要管理员权限）"""
    if not has_permission(current_user, "manage_users"):
        raise HTTPException(status_code=403, detail="权限不足，无法更新用户")
    
    if request.role_id is not None:
        update_user_role(user_id, request.role_id)
    
    if request.is_active is not None:
        if request.is_active:
            activate_user(user_id)
        else:
            deactivate_user(user_id)
    
    updated_user = get_user_by_username(str(user_id))
    return {"message": "用户更新成功", "user": updated_user}


@app.post("/api/users/{user_id}/deactivate")
async def deactivate_user_endpoint(user_id: int, current_user: dict = Depends(get_current_user)):
    """停用用户（需要管理员权限）"""
    if not has_permission(current_user, "manage_users"):
        raise HTTPException(status_code=403, detail="权限不足，无法停用用户")
    
    if deactivate_user(user_id):
        return {"message": "用户已停用"}
    raise HTTPException(status_code=404, detail="用户不存在")


@app.post("/api/users/{user_id}/activate")
async def activate_user_endpoint(user_id: int, current_user: dict = Depends(get_current_user)):
    """激活用户（需要管理员权限）"""
    if not has_permission(current_user, "manage_users"):
        raise HTTPException(status_code=403, detail="权限不足，无法激活用户")
    
    if activate_user(user_id):
        return {"message": "用户已激活"}
    raise HTTPException(status_code=404, detail="用户不存在")


# ==================== 原有 API 继续 ====================


@app.post("/api/records")
async def create_record(record: Dict[str, Any]):
    required = ["student_name", "student_id", "university", "major"]
    for field in required:
        if field not in record:
            raise HTTPException(status_code=400, detail=f"缺少必需字段：{field}")
    conn = get_db_connection()
    cursor = conn.cursor()
    try:
        cursor.execute('''INSERT INTO admission_records (student_name, student_id, university, major, admission_type, score, province, year, status, notes)
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)''',
            [record.get("student_name"), record.get("student_id"), record.get("university"), record.get("major"),
             record.get("admission_type"), record.get("score"), record.get("province"), record.get("year"),
             record.get("status", "pending"), record.get("notes")])
        conn.commit()
        record_id = cursor.lastrowid
        cursor.execute("SELECT * FROM admission_records WHERE id = ?", [record_id])
        new_record = dict(cursor.fetchone())
        conn.close()
        return {"message": "记录创建成功", "record": new_record}
    except sqlite3.IntegrityError:
        conn.close()
        raise HTTPException(status_code=400, detail=f"学号已存在：{record.get('student_id')}")

@app.get("/api/records/{record_id}")
async def get_record(record_id: int):
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM admission_records WHERE id = ?", [record_id])
    row = cursor.fetchone()
    conn.close()
    if not row:
        raise HTTPException(status_code=404, detail="记录不存在")
    return dict(row)

@app.put("/api/records/{record_id}")
async def update_record(record_id: int, record: Dict[str, Any]):
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("SELECT id FROM admission_records WHERE id = ?", [record_id])
    if not cursor.fetchone():
        conn.close()
        raise HTTPException(status_code=404, detail="记录不存在")
    update_fields = []
    values = []
    allowed = ["student_name", "student_id", "university", "major", "admission_type", "score", "province", "year", "status", "notes"]
    for field in allowed:
        if field in record:
            update_fields.append(f"{field} = ?")
            values.append(record[field])
    if not update_fields:
        conn.close()
        raise HTTPException(status_code=400, detail="没有可更新的字段")
    values.append(record_id)
    query = f"UPDATE admission_records SET {', '.join(update_fields)}, updated_at = CURRENT_TIMESTAMP WHERE id = ?"
    try:
        cursor.execute(query, values)
        conn.commit()
        cursor.execute("SELECT * FROM admission_records WHERE id = ?", [record_id])
        updated_record = dict(cursor.fetchone())
        conn.close()
        return {"message": "记录更新成功", "record": updated_record}
    except Exception as e:
        conn.close()
        raise HTTPException(status_code=500, detail=str(e))

@app.delete("/api/records/{record_id}")
async def delete_record(record_id: int):
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("SELECT id FROM admission_records WHERE id = ?", [record_id])
    if not cursor.fetchone():
        conn.close()
        raise HTTPException(status_code=404, detail="记录不存在")
    cursor.execute("DELETE FROM admission_records WHERE id = ?", [record_id])
    conn.commit()
    conn.close()
    return {"message": "记录删除成功"}


# ==================== 批量操作 API（Agent-13 新增） ====================

@app.put("/api/records/batch")
async def batch_update_records(request: Request, current_user: dict = Depends(get_current_user)):
    """
    批量修改录取记录字段
    
    请求格式：
    {
        "record_ids": [1, 2, 3, ...],
        "fields": {
            "country_id": 1,
            "university_id": 5,
            "major": "Computer Science",
            "status": "verified",
            "is_verified": 1,
            "degree": "本科",
            "scholarship": "Merit",
            "scholarship_amount": 5000
        }
    }
    
    支持批量修改的字段：
    - country_id: 国家 ID
    - university_id: 大学 ID
    - major: 专业
    - major_en: 专业英文
    - degree: 学位
    - scholarship: 奖学金
    - scholarship_amount: 奖学金金额
    - is_verified: 验证状态
    - status: 状态文本
    - requirements: 录取条件
    - portfolio: 作品集
    - article_url: 文章链接
    """
    data = await request.json()
    record_ids = data.get("record_ids", [])
    fields = data.get("fields", {})
    
    if not record_ids:
        raise HTTPException(status_code=400, detail="请提供要修改的记录 ID 列表")
    
    if not fields:
        raise HTTPException(status_code=400, detail="请提供要修改的字段")
    
    # 允许批量修改的字段
    allowed_fields = [
        "country_id", "university_id", "major", "major_en", "degree",
        "scholarship", "scholarship_amount", "is_verified", "status",
        "requirements", "portfolio", "article_url", "article_title",
        "source_school_id", "gpa", "toefl", "ielts", "sat", "act", "gre", "gmat"
    ]
    
    # 过滤只保留允许的字段
    update_fields = {k: v for k, v in fields.items() if k in allowed_fields}
    
    if not update_fields:
        raise HTTPException(status_code=400, detail="没有可更新的字段")
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    try:
        # 1. 备份原始数据（用于撤销）
        placeholders = ','.join('?' * len(record_ids))
        cursor.execute(f"SELECT * FROM admission_records WHERE id IN ({placeholders})", record_ids)
        original_records = [dict(row) for row in cursor.fetchall()]
        
        if not original_records:
            conn.close()
            raise HTTPException(status_code=404, detail="未找到任何记录")
        
        # 2. 创建撤销记录
        import json
        undo_data = {
            "operation": "batch_update",
            "record_ids": record_ids,
            "original_data": original_records,
            "updated_fields": update_fields,
            "timestamp": datetime.now().isoformat(),
            "user_id": current_user.get("id")
        }
        
        cursor.execute("""
            INSERT INTO batch_operations (operation_type, operation_data, created_by, created_at)
            VALUES (?, ?, ?, CURRENT_TIMESTAMP)
        """, ["batch_update", json.dumps(undo_data, ensure_ascii=False), current_user.get("id")])
        operation_id = cursor.lastrowid
        
        # 3. 构建更新 SQL
        update_clauses = []
        values = []
        for field, value in update_fields.items():
            update_clauses.append(f"{field} = ?")
            values.append(value)
        update_clauses.append("updated_at = CURRENT_TIMESTAMP")
        
        # 4. 执行批量更新
        values.extend(record_ids)
        query = f"UPDATE admission_records SET {', '.join(update_clauses)} WHERE id IN ({placeholders})"
        cursor.execute(query, values)
        updated_count = cursor.rowcount
        
        conn.commit()
        
        # 5. 返回结果
        return {
            "message": "批量更新成功",
            "updated_count": updated_count,
            "operation_id": operation_id,
            "can_undo": True
        }
        
    except Exception as e:
        conn.rollback()
        conn.close()
        raise HTTPException(status_code=500, detail=f"批量更新失败：{str(e)}")


@app.delete("/api/records/batch")
async def batch_delete_records(request: Request, current_user: dict = Depends(get_current_user)):
    """
    批量删除录取记录
    
    请求格式：
    {
        "record_ids": [1, 2, 3, ...],
        "confirm": true  // 需要确认标志
    }
    """
    data = await request.json()
    record_ids = data.get("record_ids", [])
    confirm = data.get("confirm", False)
    
    if not record_ids:
        raise HTTPException(status_code=400, detail="请提供要删除的记录 ID 列表")
    
    if not confirm:
        raise HTTPException(status_code=400, detail="需要确认删除操作")
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    try:
        # 1. 备份原始数据（用于撤销）
        placeholders = ','.join('?' * len(record_ids))
        cursor.execute(f"SELECT * FROM admission_records WHERE id IN ({placeholders})", record_ids)
        deleted_records = [dict(row) for row in cursor.fetchall()]
        
        if not deleted_records:
            conn.close()
            raise HTTPException(status_code=404, detail="未找到任何记录")
        
        # 2. 创建撤销记录
        import json
        undo_data = {
            "operation": "batch_delete",
            "deleted_data": deleted_records,
            "timestamp": datetime.now().isoformat(),
            "user_id": current_user.get("id")
        }
        
        cursor.execute("""
            INSERT INTO batch_operations (operation_type, operation_data, created_by, created_at)
            VALUES (?, ?, ?, CURRENT_TIMESTAMP)
        """, ["batch_delete", json.dumps(undo_data, ensure_ascii=False), current_user.get("id")])
        operation_id = cursor.lastrowid
        
        # 3. 执行批量删除
        cursor.execute(f"DELETE FROM admission_records WHERE id IN ({placeholders})", record_ids)
        deleted_count = cursor.rowcount
        
        conn.commit()
        
        return {
            "message": "批量删除成功",
            "deleted_count": deleted_count,
            "operation_id": operation_id,
            "can_undo": True
        }
        
    except Exception as e:
        conn.rollback()
        conn.close()
        raise HTTPException(status_code=500, detail=f"批量删除失败：{str(e)}")


@app.post("/api/records/batch/undo/{operation_id}")
async def undo_batch_operation(operation_id: int, current_user: dict = Depends(get_current_user)):
    """
    撤销批量操作
    
    支持撤销：
    - batch_update: 恢复原始数据
    - batch_delete: 恢复被删除的记录
    """
    conn = get_db_connection()
    cursor = conn.cursor()
    
    try:
        # 1. 获取操作记录
        cursor.execute("SELECT * FROM batch_operations WHERE id = ?", [operation_id])
        operation = cursor.fetchone()
        
        if not operation:
            conn.close()
            raise HTTPException(status_code=404, detail="操作记录不存在")
        
        operation = dict(operation)
        
        # 检查是否已撤销
        if operation.get("is_undone"):
            conn.close()
            raise HTTPException(status_code=400, detail="该操作已被撤销")
        
        # 检查操作时间（只允许撤销 24 小时内的操作）
        from datetime import datetime, timedelta
        operation_time = datetime.fromisoformat(operation["created_at"])
        if datetime.now() - operation_time > timedelta(hours=24):
            conn.close()
            raise HTTPException(status_code=400, detail="只能撤销 24 小时内的操作")
        
        import json
        operation_data = json.loads(operation["operation_data"])
        
        if operation["operation_type"] == "batch_update":
            # 撤销批量更新：恢复原始数据
            original_data = operation_data.get("original_data", [])
            for record in original_data:
                record_id = record["id"]
                # 构建恢复 SQL
                update_clauses = []
                values = []
                for key, value in record.items():
                    if key not in ["id", "created_at", "updated_at"]:
                        update_clauses.append(f"{key} = ?")
                        values.append(value)
                values.append(record_id)
                query = f"UPDATE admission_records SET {', '.join(update_clauses)}, updated_at = CURRENT_TIMESTAMP WHERE id = ?"
                cursor.execute(query, values)
        
        elif operation["operation_type"] == "batch_delete":
            # 撤销批量删除：恢复被删除的记录
            deleted_data = operation_data.get("deleted_data", [])
            for record in deleted_data:
                # 移除 id 让数据库自增
                record_copy = {k: v for k, v in record.items() if k != "id"}
                columns = ', '.join(record_copy.keys())
                placeholders = ', '.join(['?' for _ in record_copy])
                values = list(record_copy.values())
                query = f"INSERT INTO admission_records ({columns}, updated_at) VALUES ({placeholders}, CURRENT_TIMESTAMP)"
                cursor.execute(query, values)
        
        # 2. 标记操作为已撤销
        cursor.execute("""
            UPDATE batch_operations 
            SET is_undone = 1, undone_at = CURRENT_TIMESTAMP, undone_by = ?
            WHERE id = ?
        """, [current_user.get("id"), operation_id])
        
        conn.commit()
        
        return {
            "message": "撤销成功",
            "operation_id": operation_id,
            "operation_type": operation["operation_type"]
        }
        
    except Exception as e:
        conn.rollback()
        conn.close()
        raise HTTPException(status_code=500, detail=f"撤销失败：{str(e)}")


@app.get("/api/records/batch/operations")
async def get_batch_operations(limit: int = 20, current_user: dict = Depends(get_current_user)):
    """
    获取批量操作历史记录
    """
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("""
        SELECT * FROM batch_operations 
        ORDER BY created_at DESC 
        LIMIT ?
    """, [limit])
    
    operations = [dict(row) for row in cursor.fetchall()]
    conn.close()
    
    return {"operations": operations, "total": len(operations)}


# 初始化批量操作表
def init_batch_operations_table():
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS batch_operations (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            operation_type TEXT NOT NULL,
            operation_data TEXT NOT NULL,
            created_by INTEGER,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            is_undone INTEGER DEFAULT 0,
            undone_by INTEGER,
            undone_at TIMESTAMP
        )
    """)
    
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_batch_op_type ON batch_operations(operation_type)")
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_batch_op_created ON batch_operations(created_at)")
    
    conn.commit()
    conn.close()

# 初始化批量操作表
init_batch_operations_table()

@app.get("/api/tasks")
async def get_tasks(status: str = None):
    conn = get_db_connection()
    cursor = conn.cursor()
    query = "SELECT * FROM tasks"
    params = []
    if status:
        query += " WHERE status = ?"
        params.append(status)
    query += " ORDER BY created_at DESC"
    cursor.execute(query, params)
    rows = cursor.fetchall()
    conn.close()
    return {"tasks": [dict(row) for row in rows]}

@app.post("/api/tasks")
async def create_task(task: Dict[str, Any]):
    if "task_type" not in task:
        raise HTTPException(status_code=400, detail="缺少任务类型")
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("INSERT INTO tasks (task_type, status, progress) VALUES (?, 'pending', 0)", [task.get("task_type")])
    conn.commit()
    task_id = cursor.lastrowid
    cursor.execute("SELECT * FROM tasks WHERE id = ?", [task_id])
    new_task = dict(cursor.fetchone())
    conn.close()
    return {"message": "任务创建成功", "task": new_task}

# ============== 采集任务队列 API ==============

@app.get("/api/collection-tasks")
async def get_collection_tasks(status: str = None, page: int = 1, page_size: int = 50):
    """获取采集任务列表"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    query = "SELECT * FROM collection_tasks WHERE 1=1"
    params = []
    
    if status:
        query += " AND status = ?"
        params.append(status)
    
    query += " ORDER BY priority DESC, created_at DESC LIMIT ? OFFSET ?"
    params.extend([page_size, (page - 1) * page_size])
    
    cursor.execute(query, params)
    rows = cursor.fetchall()
    
    # 获取总数
    count_query = "SELECT COUNT(*) FROM collection_tasks WHERE 1=1"
    count_params = []
    if status:
        count_query += " AND status = ?"
        count_params.append(status)
    cursor.execute(count_query, count_params)
    total = cursor.fetchone()[0]
    
    conn.close()
    
    tasks = []
    for row in rows:
        task = dict(row)
        # 格式化时间
        if task.get('created_at'):
            task['created_at'] = task['created_at'].replace('T', ' ')[:19]
        if task.get('started_at'):
            task['started_at'] = task['started_at'].replace('T', ' ')[:19]
        if task.get('completed_at'):
            task['completed_at'] = task['completed_at'].replace('T', ' ')[:19]
        tasks.append(task)
    
    return {
        "tasks": tasks,
        "total": total,
        "page": page,
        "page_size": page_size,
        "total_pages": (total + page_size - 1) // page_size
    }

@app.post("/api/collection-tasks/batch")
async def batch_create_tasks(request: Request):
    """批量创建采集任务"""
    data = await request.json()
    urls = data.get("urls", [])
    
    if not urls:
        raise HTTPException(status_code=400, detail="请提供 URL 列表")
    
    # 限制批量数量
    if len(urls) > 1000:
        raise HTTPException(status_code=400, detail="单次最多支持 1000 个 URL")
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    created_count = 0
    skipped_count = 0
    
    for url in urls:
        url = url.strip()
        if not url:
            continue
        
        # 检查是否已存在
        cursor.execute("SELECT id FROM collection_tasks WHERE url = ?", [url])
        if cursor.fetchone():
            skipped_count += 1
            continue
        
        cursor.execute(
            "INSERT INTO collection_tasks (url, status, priority, progress) VALUES (?, 'pending', 5, 0)",
            [url]
        )
        created_count += 1
    
    conn.commit()
    conn.close()
    
    return {
        "message": "批量创建成功",
        "created": created_count,
        "skipped": skipped_count,
        "total": len(urls)
    }

@app.post("/api/collection-tasks")
async def create_collection_task(task: Dict[str, Any]):
    """创建单个采集任务"""
    if "url" not in task:
        raise HTTPException(status_code=400, detail="缺少 URL")
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    # 检查是否已存在
    cursor.execute("SELECT id FROM collection_tasks WHERE url = ?", [task.get("url")])
    if cursor.fetchone():
        conn.close()
        raise HTTPException(status_code=400, detail="该 URL 已存在于任务队列中")
    
    cursor.execute(
        "INSERT INTO collection_tasks (url, title, source, priority, status, progress, created_by) VALUES (?, ?, ?, ?, 'pending', 0, ?)",
        [
            task.get("url"),
            task.get("title"),
            task.get("source"),
            task.get("priority", 5),
            task.get("created_by")
        ]
    )
    conn.commit()
    task_id = cursor.lastrowid
    cursor.execute("SELECT * FROM collection_tasks WHERE id = ?", [task_id])
    new_task = dict(cursor.fetchone())
    conn.close()
    
    return {"message": "任务创建成功", "task": new_task}

@app.get("/api/collection-tasks/{task_id}")
async def get_collection_task(task_id: int):
    """获取单个任务详情"""
    conn = get_db_connection()
    cursor = conn.cursor()
    cursor.execute("SELECT * FROM collection_tasks WHERE id = ?", [task_id])
    row = cursor.fetchone()
    conn.close()
    
    if not row:
        raise HTTPException(status_code=404, detail="任务不存在")
    
    task = dict(row)
    if task.get('created_at'):
        task['created_at'] = task['created_at'].replace('T', ' ')[:19]
    if task.get('started_at'):
        task['started_at'] = task['started_at'].replace('T', ' ')[:19]
    if task.get('completed_at'):
        task['completed_at'] = task['completed_at'].replace('T', ' ')[:19]
    
    return task

@app.post("/api/collection-tasks/{task_id}/start")
async def start_collection_task(task_id: int):
    """开始执行采集任务"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("SELECT * FROM collection_tasks WHERE id = ?", [task_id])
    row = cursor.fetchone()
    
    if not row:
        conn.close()
        raise HTTPException(status_code=404, detail="任务不存在")
    
    task = dict(row)
    if task['status'] == 'processing':
        conn.close()
        raise HTTPException(status_code=400, detail="任务已在处理中")
    
    if task['status'] == 'completed':
        conn.close()
        raise HTTPException(status_code=400, detail="任务已完成，无法重复执行")
    
    # 更新状态为处理中
    cursor.execute(
        "UPDATE collection_tasks SET status = 'processing', started_at = CURRENT_TIMESTAMP, progress = 0 WHERE id = ?",
        [task_id]
    )
    conn.commit()
    conn.close()
    
    # TODO: 这里应该触发实际的采集逻辑
    # 目前只是更新状态，实际采集由后台任务处理
    
    return {"message": "任务已开始", "task_id": task_id}

@app.post("/api/collection-tasks/{task_id}/progress")
async def update_task_progress(task_id: int, progress_data: Dict[str, Any]):
    """更新任务进度"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("SELECT id FROM collection_tasks WHERE id = ?", [task_id])
    if not cursor.fetchone():
        conn.close()
        raise HTTPException(status_code=404, detail="任务不存在")
    
    progress = progress_data.get("progress", 0)
    records_extracted = progress_data.get("records_extracted", 0)
    
    cursor.execute(
        "UPDATE collection_tasks SET progress = ?, records_extracted = ? WHERE id = ?",
        [progress, records_extracted, task_id]
    )
    conn.commit()
    conn.close()
    
    return {"message": "进度更新成功"}

@app.put("/api/collection-tasks/{task_id}/complete")
async def complete_collection_task(task_id: int, complete_data: Dict[str, Any]):
    """标记任务完成"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("SELECT id FROM collection_tasks WHERE id = ?", [task_id])
    if not cursor.fetchone():
        conn.close()
        raise HTTPException(status_code=404, detail="任务不存在")
    
    status = complete_data.get("status", "completed")
    error_message = complete_data.get("error_message")
    records_extracted = complete_data.get("records_extracted", 0)
    
    if status == "failed":
        cursor.execute(
            "UPDATE collection_tasks SET status = 'failed', error_message = ?, records_extracted = ?, completed_at = CURRENT_TIMESTAMP WHERE id = ?",
            [error_message, records_extracted, task_id]
        )
    else:
        cursor.execute(
            "UPDATE collection_tasks SET status = 'completed', records_extracted = ?, completed_at = CURRENT_TIMESTAMP WHERE id = ?",
            [records_extracted, task_id]
        )
    
    conn.commit()
    conn.close()
    
    return {"message": "任务状态已更新"}

@app.delete("/api/collection-tasks/{task_id}")
async def delete_collection_task(task_id: int):
    """删除采集任务"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("SELECT id FROM collection_tasks WHERE id = ?", [task_id])
    if not cursor.fetchone():
        conn.close()
        raise HTTPException(status_code=404, detail="任务不存在")
    
    cursor.execute("DELETE FROM collection_tasks WHERE id = ?", [task_id])
    conn.commit()
    conn.close()
    
    return {"message": "任务删除成功"}

@app.post("/api/collection-tasks/batch-delete")
async def batch_delete_tasks(request: Request):
    """批量删除任务"""
    data = await request.json()
    task_ids = data.get("task_ids", [])
    
    if not task_ids:
        raise HTTPException(status_code=400, detail="请提供任务 ID 列表")
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    placeholders = ','.join('?' * len(task_ids))
    cursor.execute(f"DELETE FROM collection_tasks WHERE id IN ({placeholders})", task_ids)
    deleted_count = cursor.rowcount
    
    conn.commit()
    conn.close()
    
    return {"message": "批量删除成功", "deleted": deleted_count}

@app.post("/api/collection-tasks/batch-start")
async def batch_start_tasks(request: Request):
    """批量开始任务"""
    data = await request.json()
    task_ids = data.get("task_ids", [])
    
    if not task_ids:
        raise HTTPException(status_code=400, detail="请提供任务 ID 列表")
    
    conn = get_db_connection()
    cursor = conn.cursor()
    
    started_count = 0
    for task_id in task_ids:
        cursor.execute("SELECT status FROM collection_tasks WHERE id = ?", [task_id])
        row = cursor.fetchone()
        if row and row[0] == 'pending':
            cursor.execute(
                "UPDATE collection_tasks SET status = 'processing', started_at = CURRENT_TIMESTAMP WHERE id = ?",
                [task_id]
            )
            started_count += 1
    
    conn.commit()
    conn.close()
    
    return {"message": "批量启动成功", "started": started_count}

# ============== 统计 API ==============

@app.get("/api/stats/overview")
async def get_stats_overview():
    """总体统计：总数、国家数、大学数、奖学金总额"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    # 总记录数
    cursor.execute("SELECT COUNT(*) FROM admission_records")
    total_records = cursor.fetchone()[0]
    
    # 涉及国家数
    cursor.execute("SELECT COUNT(DISTINCT country_id) FROM admission_records WHERE country_id IS NOT NULL")
    total_countries = cursor.fetchone()[0]
    
    # 录取大学数
    cursor.execute("SELECT COUNT(DISTINCT university_id) FROM admission_records WHERE university_id IS NOT NULL")
    total_universities = cursor.fetchone()[0]
    
    # 奖学金总额
    cursor.execute("SELECT COALESCE(SUM(scholarship_amount), 0) FROM admission_records")
    total_scholarship = cursor.fetchone()[0]
    
    # 已验证记录数
    cursor.execute("SELECT COUNT(*) FROM admission_records WHERE is_verified = 1")
    verified_count = cursor.fetchone()[0]
    
    conn.close()
    
    return {
        "total_records": total_records,
        "total_countries": total_countries,
        "total_universities": total_universities,
        "total_scholarship": total_scholarship,
        "verified_count": verified_count
    }

@app.get("/api/stats/country")
async def get_stats_country():
    """按国家统计录取人数"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("""
        SELECT c.name as country, COUNT(ar.id) as count
        FROM admission_records ar
        LEFT JOIN countries c ON ar.country_id = c.id
        WHERE c.name IS NOT NULL
        GROUP BY c.name
        ORDER BY count DESC
    """)
    
    rows = cursor.fetchall()
    conn.close()
    
    return {"data": [{"country": row[0], "count": row[1]} for row in rows]}

@app.get("/api/stats/university")
async def get_stats_university(top: int = 10):
    """按大学统计录取人数（TOP10）"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("""
        SELECT u.name as university, u.name_en as university_en, COUNT(ar.id) as count
        FROM admission_records ar
        LEFT JOIN universities u ON ar.university_id = u.id
        WHERE u.name IS NOT NULL
        GROUP BY u.id, u.name, u.name_en
        ORDER BY count DESC
        LIMIT ?
    """, [top])
    
    rows = cursor.fetchall()
    conn.close()
    
    return {"data": [{"university": row[0], "university_en": row[1], "count": row[2]} for row in rows]}

@app.get("/api/stats/trend")
async def get_stats_trend():
    """年度趋势统计"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("""
        SELECT admission_year, COUNT(*) as count
        FROM admission_records
        WHERE admission_year IS NOT NULL
        GROUP BY admission_year
        ORDER BY admission_year ASC
    """)
    
    rows = cursor.fetchall()
    conn.close()
    
    return {"data": [{"year": row[0], "count": row[1]} for row in rows]}

@app.get("/api/stats/major")
async def get_stats_major(top: int = 20):
    """按专业统计录取人数（TOP20）"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    cursor.execute("""
        SELECT major, COUNT(*) as count
        FROM admission_records
        WHERE major IS NOT NULL AND major != ''
        GROUP BY major
        ORDER BY count DESC
        LIMIT ?
    """, [top])
    
    rows = cursor.fetchall()
    conn.close()
    
    return {"data": [{"major": row[0], "count": row[1]} for row in rows]}

@app.get("/api/stats/school")
async def get_stats_school():
    """按来源学校统计录取人数"""
    conn = get_db_connection()
    cursor = conn.cursor()
    
    # 直接使用 source_school 文本字段统计
    cursor.execute("""
        SELECT source_school, COUNT(*) as count
        FROM admission_records
        WHERE source_school IS NOT NULL AND source_school != ''
        GROUP BY source_school
        ORDER BY count DESC
    """)
    
    rows = cursor.fetchall()
    conn.close()
    
    return {"data": [{"school": row[0], "official_account": "", "count": row[1]} for row in rows]}

