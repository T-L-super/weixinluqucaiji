# API 响应时间监控中间件（Agent-11 新增）
@app.middleware("http")
async def monitor_api_latency(request: Request, call_next):
    start_time = time.time()
    response = await call_next(request)
    process_time = time.time() - start_time
    
    # 记录 API 响应时间（只记录/api/开头的接口）
    if request.url.path.startswith("/api/"):
        monitor_service.record_api_latency(
            endpoint=request.url.path,
            method=request.method,
            latency_sec=process_time,
            status_code=response.status_code
        )
    
    return response

def get_db_connection():
    db_path = "/root/.openclaw/workspace/大学录取信息整理系统/data/admission_system.db"
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    return conn

def init_db():
    conn = get_db_connection()
    cursor = conn.cursor()
    
    # 检查表是否已存在
    cursor.execute("SELECT name FROM sqlite_master WHERE type='table' AND name='admission_records'")
    table_exists = cursor.fetchone() is not None
    
    if not table_exists:
        # 创建新表（完整结构）
        cursor.execute('''CREATE TABLE admission_records (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            student_name TEXT NOT NULL,
            student_name_en TEXT,
            source_school_id INTEGER,
            university_id INTEGER,
            country_id INTEGER,
            major TEXT,
            major_en TEXT,
            degree TEXT,
            scholarship TEXT,
            scholarship_amount REAL,
            gpa REAL,
            toefl INTEGER,
            ielts REAL,
            sat INTEGER,
            act INTEGER,
            gre INTEGER,
            gmat INTEGER,
            application_year INTEGER,
            admission_year INTEGER,
            article_url TEXT,
            article_title TEXT,
            requirements TEXT,
            portfolio TEXT,
            is_verified INTEGER DEFAULT 0,
            data_completeness INTEGER DEFAULT 3,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )''')
        
        # 创建索引
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_admission_source ON admission_records(source_school_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_admission_university ON admission_records(university_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_admission_country ON admission_records(country_id)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_admission_year ON admission_records(admission_year)')
        cursor.execute('CREATE INDEX IF NOT EXISTS idx_admission_verified ON admission_records(is_verified)')
    
    # 确保其他表存在
    cursor.execute('''CREATE TABLE IF NOT EXISTS source_schools (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT UNIQUE NOT NULL,
        city TEXT,
        province TEXT,
        contact_person TEXT,
        contact_phone TEXT,
        official_account TEXT,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )''')
    
    cursor.execute('''CREATE TABLE IF NOT EXISTS universities (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT NOT NULL,
        name_en TEXT,
        country_id INTEGER,
        ranking_world INTEGER,
        ranking_national INTEGER,
        university_type TEXT,
        is_target INTEGER DEFAULT 0,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )''')
    
    cursor.execute('''CREATE TABLE IF NOT EXISTS countries (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT UNIQUE NOT NULL,
        name_en TEXT,
        continent TEXT,
        region TEXT,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )''')
    
    cursor.execute('''CREATE TABLE IF NOT EXISTS tasks (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        task_type TEXT NOT NULL,
        status TEXT DEFAULT 'pending',
        progress INTEGER DEFAULT 0,
        result TEXT,
        error_message TEXT,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        completed_at TIMESTAMP
    )''')
    
    # 创建采集任务队列表
    cursor.execute('''CREATE TABLE IF NOT EXISTS collection_tasks (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        url TEXT NOT NULL,
        title TEXT,
        source TEXT,
        priority INTEGER DEFAULT 5,
        status TEXT DEFAULT 'pending',
        retry_count INTEGER DEFAULT 0,
        error_message TEXT,
        records_extracted INTEGER DEFAULT 0,
        progress INTEGER DEFAULT 0,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
        started_at TIMESTAMP,
        completed_at TIMESTAMP,
        created_by TEXT
    )''')
    
    cursor.execute('CREATE INDEX IF NOT EXISTS idx_task_status ON collection_tasks(status)')
    cursor.execute('CREATE INDEX IF NOT EXISTS idx_task_priority ON collection_tasks(priority)')
    cursor.execute('CREATE INDEX IF NOT EXISTS idx_task_created ON collection_tasks(created_at)')
    
    conn.commit()
    conn.close()

# 初始化数据库
init_db()

@app.get("/", response_class=HTMLResponse)
